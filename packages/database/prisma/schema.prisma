// FinGenie Database Schema
// PostgreSQL hosted on Supabase
// Prisma ORM v6

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────
// Enums
// ─────────────────────────────────────

enum UserRole {
  user
  admin
}

enum WalletType {
  cash
  bank
  e_wallet
  other
}

enum Currency {
  VND
  USD
}

enum TransactionType {
  income
  expense
}

enum SafeMoneyMode {
  basic
  advanced
}

enum SubscriptionPlan {
  free
  monthly
  yearly
}

enum SubscriptionStatus {
  pending
  active
  cancelled
  expired
}

enum PaymentStatus {
  pending
  success
  failed
  cancelled
}

enum MessageRole {
  user
  assistant
  system
}

enum AlertType {
  overspend
  budget_warning
  saving_milestone
  system
}

// ─── Gamification Enums ───────────────
enum PetType {
  cat
  dog
  rabbit
  fox
  dragon
}

enum PetMood {
  happy
  neutral
  sad
  hungry
  excited
}

enum TaskCategory {
  saving
  spending
  tracking
  learning
  streak
}

enum TaskStatus {
  pending
  completed
  skipped
  expired
}

enum ReviewStatus {
  pending
  approved
  rejected
}

enum UserStatus {
  active
  banned
}

// ─────────────────────────────────────
// Models
// ─────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  phone         String?   @unique
  displayName   String
  avatarUrl     String?
  role          UserRole   @default(user)
  status        UserStatus @default(active)
  emailVerified Boolean    @default(false)
  premiumUntil  DateTime?

  // Firebase Auth UID for linking
  firebaseUid String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  wallets            Wallet[]
  transactions       Transaction[]
  categories         Category[]
  savingPlans        SavingPlan[]
  alerts             AlertEvent[]
  chatSessions       AIChatSession[]
  subscriptions      Subscription[]
  paymentOrders      PaymentOrder[]
  emailVerifications EmailVerification[]

  // Gamification
  pet              Pet?
  dailyTasks       DailyTask[]
  achievements     UserAchievement[]
  streak           UserStreak?
  reviews          Review[]

  @@map("users")
}

model EmailVerification {
  id        String    @id @default(cuid())
  userId    String
  email     String
  code      String
  expiresAt DateTime
  verified  Boolean   @default(false)
  usedAt    DateTime?

  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, code])
  @@index([userId])
  @@map("email_verifications")
}

model Wallet {
  id       String     @id @default(cuid())
  userId   String
  name     String
  type     WalletType @default(cash)
  balance  Decimal    @default(0) @db.Decimal(15, 2)
  currency Currency   @default(VND)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([userId])
  @@map("wallets")
}

model Transaction {
  id         String          @id @default(cuid())
  walletId   String
  userId     String
  amount     Decimal         @db.Decimal(15, 2)
  type       TransactionType
  categoryId String
  note       String?
  date       DateTime        @db.Date

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  wallet   Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])

  @@index([userId, date])
  @@index([userId, type])
  @@index([walletId, date])
  @@index([categoryId])
  @@map("transactions")
}

model Category {
  id        String  @id @default(cuid())
  name      String
  icon      String
  color     String
  isDefault Boolean @default(false)
  userId    String? // null = system default category

  // Relations
  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([name, userId])
  @@index([userId])
  @@map("categories")
}

model SavingPlan {
  id               String  @id @default(cuid())
  userId           String
  monthlyIncome    Decimal @db.Decimal(15, 2)
  fixedExpenses    Decimal @db.Decimal(15, 2)
  variableExpenses Decimal @db.Decimal(15, 2)
  savingPercent    Int // 0-100
  dailyBudget      Decimal @db.Decimal(15, 2)
  safeMoney        Decimal @db.Decimal(15, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  safeMoneyConfig SafeMoneyConfig?

  @@index([userId])
  @@map("saving_plans")
}

model SafeMoneyConfig {
  id           String        @id @default(cuid())
  savingPlanId String        @unique
  mode         SafeMoneyMode @default(basic)
  sensitivity  Int           @default(50) // 0-100
  threshold    Decimal       @db.Decimal(15, 2)

  // Relations
  savingPlan SavingPlan @relation(fields: [savingPlanId], references: [id], onDelete: Cascade)

  @@map("safe_money_configs")
}

model AlertEvent {
  id      String    @id @default(cuid())
  userId  String
  type    AlertType
  message String
  isRead  Boolean   @default(false)

  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([userId, type])
  @@map("alert_events")
}

model AIChatSession {
  id     String @id @default(cuid())
  userId String
  title  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AIMessage[]

  @@index([userId])
  @@index([userId, updatedAt])
  @@map("ai_chat_sessions")
}

model AIMessage {
  id        String      @id @default(cuid())
  sessionId String
  role      MessageRole
  content   String      @db.Text

  createdAt DateTime @default(now())

  // Relations
  session AIChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("ai_messages")
}

model Subscription {
  id     String             @id @default(cuid())
  userId String
  plan   SubscriptionPlan   @default(free)
  status SubscriptionStatus @default(pending)

  startDate DateTime  @default(now())
  endDate   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentOrders PaymentOrder[]

  @@index([userId, status])
  @@map("subscriptions")
}

model PaymentOrder {
  id              String        @id @default(cuid())
  userId          String
  subscriptionId  String
  stripeSessionId String        @unique
  amount          Decimal       @db.Decimal(15, 2)
  status          PaymentStatus @default(pending)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@index([userId])
  @@index([stripeSessionId])
  @@map("payment_orders")
}

model PaymentWebhookEvent {
  id              String    @id @default(cuid())
  stripeSessionId String
  payload         Json
  signature       String
  processedAt     DateTime?

  createdAt DateTime @default(now())

  @@index([stripeSessionId])
  @@map("payment_webhook_events")
}

// ─────────────────────────────────────
// Gamification Models
// ─────────────────────────────────────

model Pet {
  id        String  @id @default(cuid())
  userId    String  @unique
  name      String  @default("Genie")
  type      PetType @default(cat)
  level     Int     @default(1)
  xp        Int     @default(0)
  xpToNext  Int     @default(100)
  mood      PetMood @default(happy)
  hunger    Int     @default(100) // 0-100
  happiness Int     @default(100) // 0-100

  // Cosmetics
  equippedHat    String?
  equippedOutfit String?
  equippedBg     String?

  lastFedAt    DateTime?
  lastPlayedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  inventory PetItem[]

  @@index([userId])
  @@map("pets")
}

model PetItem {
  id       String @id @default(cuid())
  petId    String
  itemKey  String // e.g. "hat_crown", "outfit_ninja", "bg_beach"
  itemType String // "hat", "outfit", "background", "food"

  unlockedAt DateTime @default(now())

  // Relations
  pet Pet @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@unique([petId, itemKey])
  @@index([petId])
  @@map("pet_items")
}

model DailyTask {
  id          String       @id @default(cuid())
  userId      String
  title       String
  description String?
  category    TaskCategory
  status      TaskStatus   @default(pending)
  xpReward    Int          @default(10)
  coinReward  Int          @default(0)

  // Task data (flexible JSON for different task types)
  targetValue Int? // e.g. "add 3 transactions" → targetValue=3
  progress    Int  @default(0)

  date      DateTime @db.Date // The day this task is for
  expiresAt DateTime

  completedAt DateTime?
  createdAt   DateTime  @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([userId, status])
  @@map("daily_tasks")
}

model UserStreak {
  id             String   @id @default(cuid())
  userId         String   @unique
  currentStreak  Int      @default(0)
  longestStreak  Int      @default(0)
  lastActiveDate DateTime @db.Date
  totalCoins     Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_streaks")
}

model Achievement {
  id          String @id @default(cuid())
  key         String @unique // e.g. "first_transaction", "streak_7", "level_10"
  name        String
  description String
  icon        String
  xpReward    Int    @default(50)
  coinReward  Int    @default(0)

  // Unlock condition
  conditionType  String // "streak", "level", "transactions", "savings"
  conditionValue Int    // e.g. streak >= 7

  createdAt DateTime @default(now())

  // Relations
  users UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String @id @default(cuid())
  userId        String
  achievementId String

  unlockedAt DateTime @default(now())

  // Relations
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id])

  @@unique([userId, achievementId])
  @@index([userId])
  @@map("user_achievements")
}

// ─────────────────────────────────────
// Reviews
// ─────────────────────────────────────

model Review {
  id         String       @id @default(cuid())
  userId     String
  rating     Int          // 1–5
  content    String
  status     ReviewStatus @default(pending)
  isFeatured Boolean      @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@index([status])
  @@map("reviews")
}
